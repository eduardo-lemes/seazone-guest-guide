generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  code             String           @id
  name             String
  propertyType     String
  bedroomQuantity  Int
  bathroomQuantity Int
  guestCapacity    Int
  address          Json
  operational      Json
  rules            Json
  amenities        Json
  images           String[]
  hostName         String
  hostPhone        String
  experienceGuide  ExperienceGuide?
  insight          PropertyInsight?
}

model ExperienceGuide {
  id           String   @id @default(cuid())
  propertyCode String   @unique
  content      Json
  generatedAt  DateTime @default(now())
  property     Property @relation(fields: [propertyCode], references: [code])
}

/// Armazena o insight de IA (dica da temporada) gerado uma única vez.
/// Este registro NUNCA é sobrescrito após criado.
model PropertyInsight {
  propertyCode String   @id
  seasonalTip  String
  lockedAt     DateTime @default(now())
  property     Property @relation(fields: [propertyCode], references: [code])
}
